# ── AI providers ──────────────────────────────────────────────────────────────
# Repurpose generation is powered by OpenRouter. Provide either variable name:
OPENROUTER_API_KEY=
# OPENROUTER_KEY=sk-or-v1-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="dev.db"

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# ── OAuth providers ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudflare R2 (media storage) ───────────────────────────────────────────
# Generate an API token/keys in Cloudflare dashboard → R2 → Manage API Tokens.
# The public URL is a custom domain (or the default *.r2.cloudflarestorage.com)
# mapped to your bucket. These are server-only — never exposed to the client.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://cdn.yourdomain.com
